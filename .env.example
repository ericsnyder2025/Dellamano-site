# ─────────────────────────────────────────────────────────────
# .env.example — copy to .env.local and fill in
# ─────────────────────────────────────────────────────────────
# This scaffold assumes:
#   - Next.js 14+ App Router
#   - Vercel deployment
#   - Supabase (optional — for DB-backed dynamic pages)
#   - Anthropic Claude API (optional — for content generation agent)
#   - fal.ai (optional — for AI image generation)
#
# Keep .env.local out of git. Only .env.example is committed.

# ─────────────────────────────────────────────────────────────
# SITE (required)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
NEXT_PUBLIC_SITE_HOST=www.yourdomain.com

# ─────────────────────────────────────────────────────────────
# SUPABASE (required if using DB-backed dynamic pages)
# Site reads pages via the anon key + RLS (see
# seo-site-agents/migrations/001-pages-table.sql). Service role key is only
# needed for write-path server routes you add yourself (lead submissions, etc.).
# SUPABASE_URL (no NEXT_PUBLIC_) mirrors the agents' env var name so you can
# copy values between the two .env files without renaming.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=photos

# ─────────────────────────────────────────────────────────────
# REVALIDATION (required for on-demand ISR refresh via webhook)
# Generate a random string; match this in your webhook caller.
# ─────────────────────────────────────────────────────────────
REVALIDATE_SECRET=

# ─────────────────────────────────────────────────────────────
# CONTENT AGENT — Anthropic Claude (optional)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ─────────────────────────────────────────────────────────────
# IMAGE GENERATION — fal.ai (optional)
# ─────────────────────────────────────────────────────────────
FAL_KEY=

# ─────────────────────────────────────────────────────────────
# SEO / KEYWORD RESEARCH (optional — only if agent needs them)
# ─────────────────────────────────────────────────────────────
AHREFS_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
SERPER_API_KEY=

# ─────────────────────────────────────────────────────────────
# ANALYTICS / VERIFICATION (optional)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=

# ─────────────────────────────────────────────────────────────
# EMAIL / NOTIFICATIONS (optional)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
SLACK_WEBHOOK_URL=
